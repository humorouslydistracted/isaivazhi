<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Opt out of Android 15+ forced edge-to-edge (targetSdk 36) so the
         system reserves space for the status bar / display cutout. -->
    <style name="Theme.IsaiVazhi" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.IsaiVazhi.Splash" parent="Theme.IsaiVazhi">
        <item name="android:windowDisablePreview">false</item>
    </style>
</resources>
